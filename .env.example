# Copie para .env e preencha com os SEUS valores:
#   cp .env.example .env
# O .env NAO e versionado (esta no .gitignore).
#
# A app le estas variaveis do ambiente (nao usamos spring-dotenv):
#   set -a; source .env; set +a
#   mvn spring-boot:run
# (no IntelliJ, use o plugin EnvFile ou env vars na Run Configuration)

# Conexao com o banco (RDS publico ou MySQL local)
SPRING_DATASOURCE_URL=jdbc:mysql://<RDS-ENDPOINT>:3306/aws_class?sslMode=REQUIRED
SPRING_DATASOURCE_USERNAME=admin
DB_PASSWORD=coloque_sua_senha_aqui
